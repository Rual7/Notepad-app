<Window x:Class="Notepad_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notepad_App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New file"
                          Command="{Binding NewFileCommand}" />
                <MenuItem Header="Open file..."
                          Command="{Binding OpenFileCommand}" />
                <Separator />
                <MenuItem Header="Save file"
                          Command="{Binding SaveFileCommand}" />
                <MenuItem Header="Save file as..."
                          Command="{Binding SaveFileAsCommand}" />
                <Separator />
                <MenuItem Header="Close current file"
                          Command="{Binding CloseTabCommand}" />
                <MenuItem Header="Close all files"
                          Command="{Binding CloseAllTabsCommand}" />
                <Separator />
                <MenuItem Header="Exit"
                          Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="_Search">
                <MenuItem Header="Find..." />
                <MenuItem Header="Replace..." />
                <MenuItem Header="Replace All..." />
                <Separator />
                <MenuItem Header="Selected tab" IsCheckable="True" IsChecked="True" />
                <MenuItem Header="All tabs" IsCheckable="True" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Tree View"
                          IsCheckable="True"
                          IsChecked="{Binding IsTreeViewVisible}"
                          Command="{Binding ToggleTreeViewCommand}" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About"
                          Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top"  Background="White" >
            <Button Command="{Binding NewFileCommand}" ToolTip="New">
                <Image Source="Resources/Icons/new.png" Width="16" Height="16"/>
            </Button>
            
            <Button Command="{Binding OpenFileCommand}" ToolTip="Open">
                <Image Source="Resources/Icons/open.png" Width="16" Height="16"/>
            </Button>
            
            <Button Command="{Binding SaveFileCommand}" ToolTip="Save">
                <Image Source="Resources/Icons/save.png" Width="16" Height="16"/>
            </Button>
           
            <Separator/>
            
            <Button Command="{Binding CloseTabCommand}" ToolTip="Close">
                <Image Source="Resources/Icons/close.png" Width="16" Height="16"/>
            </Button>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="LightGray"
                    BorderThickness="0,0,1,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTreeViewVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <TreeView x:Name="ProjectTreeView"
          ItemsSource="{Binding TreeItems}"
          PreviewMouseDoubleClick="ProjectTreeView_PreviewMouseDoubleClick">

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded" />
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>

                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="LightGray" />

            <TabControl Grid.Column="2"
                        ItemsSource="{Binding Tabs}"
                        SelectedItem="{Binding SelectedTab}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayTitle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <Button Content="×"
                                    Width="18"
                                    Height="18"
                                    Padding="0"
                                    FontWeight="Bold"
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                    CommandParameter="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 FontSize="14" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
